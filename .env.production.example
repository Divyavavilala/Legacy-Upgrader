# Copy to .env.production and fill in secrets before: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

POSTGRES_USER=legacyupgrader
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=legacyupgrader
DATABASE_URL=postgresql://legacyupgrader:change-me-strong-password@postgres:5432/legacyupgrader?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_REFRESH_PEPPER=change-me-refresh-pepper-min-32-chars-long!!

CORS_ORIGIN=https://app.example.com
API_PORT=3000
WEB_PORT=8080
WORKER_HEALTH_PORT=3001

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002

AI_ENABLED=true
# OPENAI_API_KEY=
SWAGGER_ENABLED=false

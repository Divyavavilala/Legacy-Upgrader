NODE_ENV=development
APP_NAME=LegacyUpgrader API
PORT=3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://legacyupgrader:legacyupgrader@localhost:5432/legacyupgrader?schema=public

# JWT (use long random strings in production — min 32 chars)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_REFRESH_PEPPER=change-me-refresh-pepper-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Repository scan workspaces (absolute or relative path)
SCAN_WORKSPACE_ROOT=tmp/scans
SCAN_CLONE_TIMEOUT_MS=300000
SCAN_TOTAL_TIMEOUT_MS=600000
SCAN_CLONE_DEPTH=1
SCAN_CLONE_MAX_RETRIES=2

# AI modernization (heuristic fallback when no API keys are set)
AI_ENABLED=true
AI_AUTO_RUN_AFTER_SCAN=true
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=heuristic
AI_MAX_TOKENS_PER_REQUEST=4096
AI_MAX_CONTEXT_CHARS=32000
AI_RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_MINUTE=120
API_KEY_RATE_LIMIT_PER_MINUTE=60

# Observability
LOG_FORMAT=text
METRICS_ENABLED=true
TRUST_PROXY=false
SWAGGER_ENABLED=true
WORKER_HEALTH_PORT=3001
API_ONLY=false
RUN_MIGRATIONS=false
AI_CACHE_TTL_SECONDS=3600
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

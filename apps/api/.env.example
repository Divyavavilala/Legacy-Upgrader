NODE_ENV=development
APP_NAME=LegacyUpgrader API
PORT=3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://legacyupgrader:legacyupgrader@localhost:5432/legacyupgrader?schema=public

# JWT (use long random strings in production — min 32 chars)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_REFRESH_PEPPER=change-me-refresh-pepper-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

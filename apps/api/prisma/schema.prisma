// =============================================================================
// LegacyUpgrader — PostgreSQL schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

enum RepositoryProvider {
  GITHUB
  GITLAB
  BITBUCKET
  AZURE_DEVOPS
  LOCAL
  OTHER
}

enum ScanStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum FindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingCategory {
  SECURITY
  DEPENDENCY
  CODE_QUALITY
  ARCHITECTURE
  LICENSING
  PERFORMANCE
  OTHER
}

enum DependencyIssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MigrationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MigrationEffort {
  TRIVIAL
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum MigrationRecommendationStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DISMISSED
  DEFERRED
}

enum ModernizationReportStatus {
  DRAFT
  GENERATING
  PUBLISHED
  ARCHIVED
}

enum QueuedJobType {
  SCAN_REPOSITORY
  GENERATE_REPORT
  SYNC_REPOSITORY
  MIGRATION_ANALYSIS
  DEPENDENCY_AUDIT
  OTHER
}

enum QueuedJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
  CANCELLED
}

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ApiKeyScope {
  READ_REPOSITORIES
  WRITE_REPOSITORIES
  TRIGGER_SCANS
  READ_SCANS
  READ_USAGE
  MANAGE_SETTINGS
}

enum AuditAction {
  ORGANIZATION_UPDATED
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED
  ORGANIZATION_SWITCHED
  REPOSITORY_CREATED
  REPOSITORY_DELETED
  SCAN_TRIGGERED
  SCAN_COMPLETED
  SCAN_FAILED
  API_KEY_CREATED
  API_KEY_ROTATED
  API_KEY_REVOKED
  AI_ANALYSIS_STARTED
  AI_ANALYSIS_COMPLETED
}

enum NotificationType {
  SCAN_COMPLETED
  SCAN_FAILED
  AI_REPORT_COMPLETED
  MEMBER_INVITED
  QUOTA_WARNING
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SLACK
  DISCORD
  WEBHOOK
}

// -----------------------------------------------------------------------------
// Core tenancy
// -----------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  members       OrganizationMember[]
  invitations   OrganizationInvitation[]
  repositories  Repository[]
  queuedJobs    QueuedJob[]
  aiTokenUsage  AiTokenUsage[]
  subscription  OrganizationSubscription?
  usageMetrics  OrganizationUsageMetric[]
  auditLogs     AuditLog[]
  apiKeys       OrganizationApiKey[]
  notifications Notification[]
  webhookEndpoints WebhookEndpoint[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  email          String   @unique
  name           String?
  passwordHash   String   @map("password_hash")
  role           UserRole @default(DEVELOPER)
  isActive       Boolean  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens  RefreshToken[]
  queuedJobs     QueuedJob[]          @relation("QueuedJobCreatedBy")
  memberships    OrganizationMember[]
  invitationsSent OrganizationInvitation[] @relation("InvitationInvitedBy")
  notifications  Notification[]
  auditLogs      AuditLog[]

  @@index([organizationId])
  @@index([organizationId, role])
  @@map("users")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           UserRole @default(DEVELOPER)
  joinedAt       DateTime @default(now()) @map("joined_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_members")
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  email          String
  role           UserRole         @default(DEVELOPER)
  tokenHash      String           @unique @map("token_hash")
  invitedById    String           @map("invited_by_id")
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([email])
  @@map("organization_invitations")
}

model Plan {
  id                    String           @id @default(cuid())
  tier                  SubscriptionTier @unique
  name                  String
  maxRepositories       Int              @map("max_repositories")
  maxScansPerMonth      Int              @map("max_scans_per_month")
  maxAiTokensPerMonth   Int              @map("max_ai_tokens_per_month")
  maxMembers            Int              @map("max_members")
  reportRetentionDays   Int              @map("report_retention_days")
  maxApiKeys            Int              @default(5) @map("max_api_keys")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  subscriptions OrganizationSubscription[]

  @@map("plans")
}

model OrganizationSubscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique @map("organization_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("organization_subscriptions")
}

model OrganizationUsageMetric {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  periodYear       Int      @map("period_year")
  periodMonth      Int      @map("period_month")
  scanCount        Int      @default(0) @map("scan_count")
  aiTokensUsed     Int      @default(0) @map("ai_tokens_used")
  repositoryCount  Int      @default(0) @map("repository_count")
  workerJobsCount  Int      @default(0) @map("worker_jobs_count")
  storageBytes     BigInt   @default(0) @map("storage_bytes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodYear, periodMonth])
  @@index([organizationId])
  @@map("organization_usage_metrics")
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  userId         String?     @map("user_id")
  apiKeyId       String?     @map("api_key_id")
  action         AuditAction
  resourceType   String?     @map("resource_type")
  resourceId     String?     @map("resource_id")
  metadata       Json?
  ipAddress      String?     @map("ip_address")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey       OrganizationApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model OrganizationApiKey {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  name           String
  keyPrefix      String        @map("key_prefix")
  keyHash        String        @unique @map("key_hash")
  scopes         ApiKeyScope[]
  lastUsedAt     DateTime?     @map("last_used_at")
  expiresAt      DateTime?     @map("expires_at")
  revokedAt      DateTime?     @map("revoked_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@index([keyPrefix])
  @@map("organization_api_keys")
}

model Notification {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  userId         String?             @map("user_id")
  type           NotificationType
  channel        NotificationChannel @default(IN_APP)
  title          String
  body           String?             @db.Text
  metadata       Json?
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  url            String
  secret         String
  events         String[] @default([])
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("webhook_endpoints")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// -----------------------------------------------------------------------------
// Repositories & scans
// -----------------------------------------------------------------------------

model Repository {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  name           String
  slug           String
  url            String?
  provider       RepositoryProvider @default(GITHUB)
  defaultBranch  String?            @default("main") @map("default_branch")
  externalId     String?            @map("external_id")
  isActive       Boolean            @default(true) @map("is_active")
  lastSyncedAt   DateTime?          @map("last_synced_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scans                    Scan[]
  migrationRecommendations MigrationRecommendation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("repositories")
}

model Scan {
  id           String     @id @default(cuid())
  repositoryId String     @map("repository_id")
  status       ScanStatus @default(PENDING)
  progress     Int        @default(0)
  currentStage String?    @map("current_stage")
  branch       String?
  commitSha    String?    @map("commit_sha")
  triggeredBy  String?    @map("triggered_by")
  startedAt    DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")
  errorMessage String?    @map("error_message") @db.Text
  metadata     Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  repository               Repository                @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  findings                 Finding[]
  dependencyIssues         DependencyIssue[]
  migrationRecommendations MigrationRecommendation[]
  modernizationReport      ModernizationReport?
  queuedJobs               QueuedJob[]
  aiInsights               AiInsight[]
  aiTokenUsage             AiTokenUsage[]

  @@index([repositoryId])
  @@index([repositoryId, status])
  @@index([status])
  @@index([createdAt])
  @@map("scans")
}

// -----------------------------------------------------------------------------
// Scan results
// -----------------------------------------------------------------------------

model Finding {
  id          String          @id @default(cuid())
  scanId      String          @map("scan_id")
  severity    FindingSeverity
  category    FindingCategory
  title       String
  description String?         @db.Text
  filePath    String?         @map("file_path")
  lineStart   Int?            @map("line_start")
  lineEnd     Int?            @map("line_end")
  ruleId      String?         @map("rule_id")
  fingerprint String?
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([scanId, severity])
  @@index([scanId, category])
  @@index([fingerprint])
  @@map("findings")
}

model DependencyIssue {
  id                 String                  @id @default(cuid())
  scanId             String                  @map("scan_id")
  packageName        String                  @map("package_name")
  currentVersion     String?                 @map("current_version")
  recommendedVersion String?               @map("recommended_version")
  severity           DependencyIssueSeverity
  ecosystem          String?
  isDirect           Boolean                 @default(true) @map("is_direct")
  cveIds             String[]                @default([]) @map("cve_ids")
  metadata           Json?
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([scanId, severity])
  @@index([packageName])
  @@map("dependency_issues")
}

// -----------------------------------------------------------------------------
// AI modernization intelligence
// -----------------------------------------------------------------------------

model AiInsight {
  id         String   @id @default(cuid())
  scanId     String   @map("scan_id")
  agentType  String   @map("agent_type")
  title      String
  summary    String?  @db.Text
  content    Json
  confidence Float?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([scanId, agentType])
  @@map("ai_insights")
}

model AiTokenUsage {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  scanId           String?  @map("scan_id")
  provider         String
  model            String
  agentType        String?  @map("agent_type")
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  estimatedCostUsd Decimal? @map("estimated_cost_usd") @db.Decimal(10, 6)
  cacheHit         Boolean  @default(false) @map("cache_hit")
  requestHash      String?  @map("request_hash")
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scan           Scan?          @relation(fields: [scanId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([scanId])
  @@index([provider])
  @@index([createdAt])
  @@map("ai_token_usage")
}

// -----------------------------------------------------------------------------
// Modernization outputs
// -----------------------------------------------------------------------------

model MigrationRecommendation {
  id           String                        @id @default(cuid())
  repositoryId String?                       @map("repository_id")
  scanId       String?                       @map("scan_id")
  title        String
  description  String?                       @db.Text
  priority     MigrationPriority             @default(MEDIUM)
  effort       MigrationEffort               @default(MEDIUM)
  targetStack  String?                       @map("target_stack")
  status       MigrationRecommendationStatus @default(OPEN)
  metadata     Json?
  createdAt    DateTime                      @default(now()) @map("created_at")
  updatedAt    DateTime                      @updatedAt @map("updated_at")

  repository Repository? @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  scan         Scan?       @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([scanId])
  @@index([status])
  @@index([priority])
  @@map("migration_recommendations")
}

model ModernizationReport {
  id          String                    @id @default(cuid())
  scanId      String                    @unique @map("scan_id")
  status      ModernizationReportStatus @default(DRAFT)
  title       String?
  summary     String?                   @db.Text
  content     Json?
  publishedAt DateTime?                 @map("published_at")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("modernization_reports")
}

// -----------------------------------------------------------------------------
// Background jobs
// -----------------------------------------------------------------------------

model QueuedJob {
  id             String          @id @default(cuid())
  organizationId String?         @map("organization_id")
  scanId         String?         @map("scan_id")
  createdById    String?         @map("created_by_id")
  type           QueuedJobType
  status         QueuedJobStatus @default(PENDING)
  priority       Int             @default(0)
  payload        Json?
  result         Json?
  attempts       Int             @default(0)
  maxAttempts    Int             @default(3) @map("max_attempts")
  scheduledAt    DateTime?       @map("scheduled_at")
  startedAt      DateTime?       @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  errorMessage   String?         @map("error_message") @db.Text
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scan           Scan?          @relation(fields: [scanId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("QueuedJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([scanId])
  @@index([status])
  @@index([type, status])
  @@index([scheduledAt])
  @@index([priority, createdAt])
  @@map("queued_jobs")
}

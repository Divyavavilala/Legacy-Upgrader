{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@legacyupgrader/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@legacyupgrader/rule-definitions": ["../../packages/rule-definitions/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/rule-definitions" }
  ]
}
